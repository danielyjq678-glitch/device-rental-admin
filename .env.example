# 云环境 ID
CLOUD_ENV=cloud1-d0gtbh90x8d74a386

# CloudBase 密钥（必填）
CLOUD_SECRET_ID=YOUR_CLOUD_SECRET_ID
CLOUD_SECRET_KEY=YOUR_CLOUD_SECRET_KEY

# 管理员密码
ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD

# 分校管理员：school_name:password;school_name2:password2
BRANCH_ADMINS=school1:pwd1;school2:pwd2

# CloudRun API 调用共享密钥（可选，不设则从 CLOUD_SECRET_ID 派生）
# ADMIN_API_KEY=YOUR_ADMIN_API_KEY

# 微信小程序
WECHAT_APPID=YOUR_WECHAT_APPID
WECHAT_SECRET=YOUR_WECHAT_SECRET

# 百炼 API Key（可选）
# BAILIAN_API_KEY=YOUR_BAILIAN_API_KEY
